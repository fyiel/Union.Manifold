{
  "name": "union-manifold",
  "version": "1.0.5",
  "description": "Union.Manifold, a multi source game launcher forked from UnionCrax.Direct",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "fyiel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UnionCrax-Team/UnionCrax.Direct.git"
  },
  "bugs": {
    "url": "https://github.com/UnionCrax-Team/UnionCrax.Direct/issues"
  },
  "homepage": "https://github.com/UnionCrax-Team/UnionCrax.Direct#readme",
  "scripts": {
    "setup": "node ./node_modules/electron/install.js",
    "dev": "concurrently -k \"pnpm:dev:renderer\" \"pnpm:dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:electron": "wait-on http://localhost:5173 && node ./scripts/run-electron.cjs ./electron/main.cjs",
    "build": "pnpm -s build:renderer && pnpm -s build:electron",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build:electron": "node ./scripts/build-electron.cjs",
    "fetch-gcpad": "node ./scripts/fetch-gcpad.cjs",
    "fetch-aria2": "node ./scripts/fetch-aria2.cjs",
    "fetch-aria2:all": "node ./scripts/fetch-aria2.cjs --all",
    "fetch-7zip": "node ./scripts/fetch-7zip.cjs",
    "fetch-7zip:all": "node ./scripts/fetch-7zip.cjs --all",
    "pack": "pnpm -s fetch-gcpad && pnpm -s fetch-aria2:all && pnpm -s fetch-7zip:all && pnpm -s build && electron-builder",
    "release:version": "node ./scripts/release-version.cjs",
    "rebuild-native": "node scripts/rebuild-native.cjs",
    "postinstall": "pnpm rebuild-native || echo 'Native overlay addon build skipped (install C++ build tools to enable)' && node ./scripts/fetch-aria2.cjs && node ./scripts/fetch-7zip.cjs"
  },
  "dependencies": {
    "7zip-bin": "^5.0.0",
    "@animateicons/react": "^0.3.3",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.6",
    "class-variance-authority": "^0.7.1",
    "classic-level": "^3.0.0",
    "clsx": "^2.1.1",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.5.1",
    "fuse.js": "^7.1.0",
    "geist": "^1.5.1",
    "lucide-react": "^0.454.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.31.6",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "node-addon-api": "^7.1.1",
    "node-gyp": "^10.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.9.2",
    "vite": "^6.4.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "icon": "assets/icon.ico",
    "appId": "fyi.pumg.unionmanifold",
    "productName": "Union.Manifold",
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "fyiel",
        "repo": "Union.Manifold"
      }
    ],
    "directories": {
      "output": "dist-packaged",
      "buildResources": "assets"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "renderer/dist/**/*",
      "package.json",
      "CHANGELOG.md"
    ],
    "asarUnpack": [
      "node_modules/7zip-bin",
      "electron/native/build/**/*",
      "assets/bin/aria2/**",
      "assets/bin/7zip/**"
    ],
    "protocols": [
      {
        "name": "UnionCrax",
        "schemes": [
          "unioncrax"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "files": [
        "!assets/bin/aria2/linux-*/**",
        "!assets/bin/7zip/linux-*/**",
        "!assets/bin/7zip/darwin-*/**"
      ],
      "target": [
        "nsis",
        "zip"
      ],
      "extraResources": [
        {
          "from": "overlay-dll/build/Release/uc-overlay-x64.dll",
          "to": "uc-overlay-x64.dll"
        },
        {
          "from": "gcpad-dll/gcpad.dll",
          "to": "gcpad.dll"
        },
        {
          "from": "gcpad-dll/SDL2.dll",
          "to": "SDL2.dll"
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}",
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UnionCrax.Direct",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "linux": {
      "files": [
        "!assets/bin/aria2/win32-*/**",
        "!assets/bin/7zip/win32-*/**",
        "!assets/bin/7zip/darwin-*/**"
      ],
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "assets/icons",
      "extraResources": [
        {
          "from": "gcpad-dll/libgcpad.so.1.0.0",
          "to": "libgcpad.so.1.0.0"
        },
        {
          "from": "gcpad-dll/libgcpad.so.1",
          "to": "libgcpad.so.1"
        },
        {
          "from": "gcpad-dll/libgcpad.so",
          "to": "libgcpad.so"
        }
      ]
    }
  },
  "pnpm": {
    "overrides": {
      "react-server-dom-webpack": "19.2.3",
      "react-server-dom-parcel": "19.2.3",
      "react-server-dom-turbopack": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "classic-level",
      "electron"
    ]
  }
}
