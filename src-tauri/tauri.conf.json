{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Union.Manifold",
  "version": "1.0.4",
  "identifier": "fyi.pumg.unionmanifold",
  "build": {
    "beforeDevCommand": "pnpm dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:renderer",
    "frontendDist": "../renderer/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Union.Manifold",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 680,
        "decorations": false,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/aria2c", "binaries/7z"],
    "resources": ["resources/cacert.pem"],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["unioncrax", "unionmanifold"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/fyiel/Union.Manifold/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IHJlcGxhY2Ugd2l0aCBhIHJlYWwgbWluaXNpZ24gcHVibGljIGtleQpSV1FBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUE="
    }
  }
}
